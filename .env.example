# HanaForge settings — names use the HANAFORGE_ prefix (see infrastructure/config/settings.py).
HANAFORGE_GCP_PROJECT_ID=hanaforge-dev
HANAFORGE_FIRESTORE_DATABASE=(default)
HANAFORGE_GCS_BUCKET=hanaforge-artefacts-dev
HANAFORGE_ANTHROPIC_API_KEY=sk-ant-xxx
HANAFORGE_GOOGLE_AI_API_KEY=
HANAFORGE_SAP_DEFAULT_HOST=
HANAFORGE_USE_FIRESTORE=false
HANAFORGE_AUTH_ENABLED=false
# HANA → BigQuery (optional)
HANAFORGE_HANA_ADDRESS=
HANAFORGE_HANA_PORT=443
HANAFORGE_HANA_USER=
HANAFORGE_HANA_PASSWORD=
HANAFORGE_BQ_USE_REAL_CLIENT=false
HANAFORGE_BQ_DEFAULT_LOCATION=US
